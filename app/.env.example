# Copy to app/.env and fill in. app/.env is gitignored.
# Read by app/server.py locally and injected into the container via
# docker-compose `env_file`.

# Enables speaker diarization. Requires accepting the
# pyannote/speaker-diarization-community-1 user agreement on Hugging Face.
# Leave blank to run transcription + alignment only.
HF_TOKEN=

# Optional overrides (defaults shown).
# WHISPERX_MODEL only seeds the INITIAL default model; clients pick a model per
# upload and switch the global default at runtime (persisted in SQLite). Allowed:
# tiny tiny.en base base.en small small.en medium medium.en large-v2 large-v3 distil-large-v3
# WHISPERX_MODEL=small
# WHISPERX_BATCH_SIZE=8
# WHISPERX_MAX_UPLOAD_MB=200
