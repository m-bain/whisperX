# Copy to app/.env and fill in. app/.env is gitignored.
# Read by app/server.py locally and injected into the container via
# docker-compose `env_file`.

# Hugging Face token. OPTIONAL — speaker diarization works out of the box from
# the vendored pyannote model committed under app/models/ (see
# app/diarize_model.py), so no token is needed to transcribe + diarize.
#
# A token is only used to REFRESH that model to a newer revision (the "Refresh
# from Hugging Face" button in Settings, or app/scripts/vendor_diarize_model.py).
# To refresh you must accept the pyannote/speaker-diarization-community-1 user
# agreement on Hugging Face. Normally set the token via onboarding / Settings,
# which stores it in your OS keyring (macOS Keychain / Windows Credential Locker
# / Linux Secret Service). Set it here only to override the keyring (this env
# value wins) or on a headless host with no keyring backend.
HF_TOKEN=

# Optional overrides (defaults shown).
# WHISPERX_MODEL only seeds the INITIAL default model; clients pick a model per
# upload and switch the global default at runtime (persisted in SQLite). Allowed:
# tiny tiny.en base base.en small small.en medium medium.en large-v2 large-v3 distil-large-v3
# WHISPERX_MODEL=small
# WHISPERX_BATCH_SIZE=8
# WHISPERX_MAX_UPLOAD_MB=200
